#!/bin/sh

TARGET_FILES=$(git diff --cached --name-only --diff-filter=ACMR -z | tr '\0' '\n' | grep -E '^src/.*\.(js|jsx|ts|tsx)$' | grep -v '^src/api/' || true)

if [ -z "$TARGET_FILES" ]; then
  exit 0
fi

echo "Running ESLint for staged src files..."
echo "========================================"

printf '%s\n' "$TARGET_FILES" | while IFS= read -r file; do
  [ -z "$file" ] && continue
  npx eslint --cache --cache-location .eslintcache "$file" || exit 1
done
if [ $? -ne 0 ]; then
  echo "@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@"
  echo "@ ESLint failed, aborting commit"
  echo "@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@"
  exit 1
fi

echo "========================================"
